{
  "name": "weather-app-root",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "browserslist": [
    "> 0.5% and last 1 year"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "node ./scripts/dev-full.mjs",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint:a11y": "biome check src --only=a11y --formatter-enabled=false",
    "lint:a11y:write": "biome check src --only=a11y --formatter-enabled=false --write",
    "preview": "vite preview",
    "repl": "node ./test/repl/run.mjs",
    "repl:playwright": "node ./test/repl/playwright-run.mjs",
    "test:playwright:session-key": "node ./test/repl/playwright-session-key-run.mjs",
    "test:p2p:sync": "node ./test/p2p/playwright-p2p-sync.mjs",
    "test:p2p:failover": "node ./test/p2p/playwright-p2p-failover.mjs",
    "test:p2p": "node ./test/p2p/playwright-p2p-sync.mjs && node ./test/p2p/playwright-p2p-failover.mjs"
  },
  "dependencies": {
    "@meteocons/lottie": "^0.1.0",
    "lottie-web": "^5.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001788",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "ws": "^8.20.0"
  }
}
